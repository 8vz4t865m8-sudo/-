default_platform(:ios)

platform :ios do
  desc "Build IPA for Abyss Survivor"
  lane :beta do
    keychain_name = "build-keychain-#{Time.now.to_i}"
    keychain_password = SecureRandom.uuid

    begin
      # Create temp keychain
      create_keychain(
        name: keychain_name,
        password: keychain_password,
        unlock: true,
        timeout: 0,
        lock_when_sleeps: false,
        add_to_search_list: true
      )

      # Decode and import certificate
      cert_path = "#{Dir.tmpdir}/cert.p12"
      File.write(cert_path, Base64.decode64(ENV['BUILD_CERTIFICATE_BASE64']))
      import_certificate(
        certificate_path: cert_path,
        certificate_password: ENV['P12_PASSWORD'] || "",
        keychain_name: keychain_name,
        keychain_password: keychain_password
      )
      File.delete(cert_path)

      # Decode and install provisioning profile
      profile_path = "#{Dir.tmpdir}/profile.mobileprovision"
      File.write(profile_path, Base64.decode64(ENV['BUILD_PROVISION_PROFILE_BASE64']))
      install_provisioning_profile(path: profile_path)

      # Update signing settings
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "../ios/App/App.xcodeproj",
        code_sign_identity: "iPhone Distribution",
        profile_name: ENV['APPLE_PROFILE_NAME'],
        bundle_identifier: ENV['BUNDLE_IDENTIFIER'],
        team_id: ENV['APP_STORE_CONNECT_TEAM_ID']
      )

      update_project_team(
        path: "../ios/App/App.xcodeproj",
        teamid: ENV['APP_STORE_CONNECT_TEAM_ID']
      )

      # Increment build number
      increment_build_number(
        build_number: (Time.now.to_i / 1000).to_s,
        xcodeproj: "../ios/App/App.xcodeproj"
      )

      # Build IPA
      build_app(
        workspace: "../ios/App/App.xcworkspace",
        scheme: "App",
        configuration: "Release",
        export_method: "app-store",
        output_directory: "../fastlane/build",
        output_name: "AbyssSurvivor.ipa",
        export_options: {
          provisioningProfiles: {
            ENV['BUNDLE_IDENTIFIER'] => ENV['APPLE_PROFILE_NAME']
          }
        }
      )

    ensure
      delete_keychain(name: keychain_name)
      File.delete(profile_path) if File.exist?(profile_path)
    end
  end
end
